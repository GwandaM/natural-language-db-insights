# LLM provider toggle: "gemini" (default) or "bedrock"
LLM_PROVIDER="gemini"

# --- Gemini (used when LLM_PROVIDER=gemini) ---
GOOGLE_GENERATIVE_AI_API_KEY="your_gemini_api_key_here"
# Optional alias if you prefer Google's native env name:
# GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"

# --- AWS Bedrock (used when LLM_PROVIDER=bedrock) ---
# Defaults to Claude Sonnet 4.5. Set to the Claude Sonnet 4.6 inference-profile
# ID (e.g. "us.anthropic.claude-sonnet-4-6-YYYYMMDD-v1:0") once you've
# confirmed availability in your AWS region.
BEDROCK_MODEL_ID="us.anthropic.claude-sonnet-4-5-20250929-v1:0"
AWS_REGION="us-east-1"
# Leave AWS credentials unset to use the default AWS credential chain
# (IAM role, ~/.aws/credentials, instance profile, etc.).
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_SESSION_TOKEN=""

POSTGRES_URL="..."
POSTGRES_PRISMA_URL="..."
POSTGRES_URL_NO_SSL="..."
POSTGRES_URL_NON_POOLING="..."
POSTGRES_USER="..."
POSTGRES_HOST="..."
POSTGRES_PASSWORD="..."
POSTGRES_DATABASE="..."
